generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String    @id
  email        String    @unique
  name         String?
  avatarUrl    String?
  schoolName   String?
  verified     Boolean   @default(false)
  responseRate Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  role         UserRole  @default(USER)
  onboarded    Boolean   @default(false)
  lastActiveAt DateTime?

  sellerProfile    SellerProfile?
  listings         Listing[]
  purchases        Purchase[]       @relation("Buyer")
  sales            Purchase[]       @relation("Seller")
  notifications    Notification[]
  messageThreadsAsA MessageThread[] @relation("ThreadUserA")
  messageThreadsAsB MessageThread[] @relation("ThreadUserB")
  messages         Message[]
  reportsFiled     Report[]         @relation("ReportReporter")
  reportsReceived  Report[]         @relation("ReportTarget")
  wishlists        Wishlist[]
  priceAlerts      PriceAlert[]
  courseSchedules  CourseSchedule[]
}

model Listing {
  id            String        @id @default(cuid())
  sellerId      String
  seller        User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  title         String
  courseCode    String?
  author        String
  isbn          String
  condition     String
  subject       String
  description   String?
  edition       String?
  price         Decimal       @db.Decimal(10, 2)
  type          ListingType
  status        ListingStatus @default(AVAILABLE)
  imageUrls     String?
  isFeatured    Boolean       @default(false)
  featuredUntil DateTime?
  viewCount     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  images         ListingImage[]
  purchases      Purchase[]
  reports        Report[]
  messageThreads MessageThread[]
  wishlists      Wishlist[]
  priceAlerts    PriceAlert[]
  priceHistory   PriceHistory[]
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([listingId, position])
}

enum ListingType {
  FIXED
}

enum ListingStatus {
  AVAILABLE
  SOLD
}

model Purchase {
  id           String         @id @default(cuid())
  listingId    String
  listing      Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId      String
  buyer        User           @relation("Buyer", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId     String
  seller       User           @relation("Seller", fields: [sellerId], references: [id], onDelete: Cascade)
  status           PurchaseStatus @default(PENDING)
  finalPrice       Decimal        @db.Decimal(10, 2)
  platformFeeCents Int           @default(0)
  stripePaymentId  String?
  meetupDate       DateTime?
  purchasedAt      DateTime       @default(now())

  meetup Meetup?

  @@unique([listingId])
  @@index([buyerId, status])
  @@index([sellerId, status])
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  linkUrl   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SellerProfile {
  userId      String   @id
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String
  bio         String?
  totalSales  Int      @default(0)
  joinedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MessageThread {
  id        String    @id @default(cuid())
  userAId   String
  userA     User      @relation("ThreadUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId   String
  userB     User      @relation("ThreadUserB", fields: [userBId], references: [id], onDelete: Cascade)
  listingId String?
  listing   Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userAId, userBId, listingId])
}

model Message {
  id        String        @id @default(cuid())
  threadId  String
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  read      Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([threadId, createdAt])
}

model Meetup {
  id         String       @id @default(cuid())
  purchaseId String       @unique
  purchase   Purchase     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  startTime  DateTime
  endTime    DateTime?
  location   String?
  status     MeetupStatus @default(SCHEDULED)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

enum MeetupStatus {
  SCHEDULED
  PENDING
  COMPLETED
  CANCELLED
}

model Report {
  id           String      @id @default(cuid())
  reporterId   String
  reporter     User        @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUserId String?
  targetUser   User?       @relation("ReportTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  listingId    String?
  listing      Listing?    @relation(fields: [listingId], references: [id], onDelete: SetNull)
  reason       String
  details      String?
  status       ReportStatus @default(OPEN)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

model PriceHistory {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  @@index([listingId, createdAt])
}

model PriceAlert {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  targetPrice Decimal  @db.Decimal(10, 2)
  triggered   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([userId, listingId])
  @@index([listingId])
}

model CourseSchedule {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseCode String
  courseName String?
  semester   String?
  createdAt  DateTime @default(now())

  @@unique([userId, courseCode])
  @@index([userId])
}
